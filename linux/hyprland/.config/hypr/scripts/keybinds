# MOVE / RESIZE WINDOWS USING MOUSE
binds {
    drag_threshold = 10  # Fire a drag event only after dragging for more than 10px
}
bindm = CTRL_SHIFT, mouse:272, movewindow      # ALT + LMB: Move a window by dragging more than 10px.
bindm = CTRL_SHIFT, mouse:273, resizewindow

