#!/usr/bin/env python3
"""
Middle Mouse Drag Workspace Switcher for Hyprland
macOS-style: Each drag switches ONE workspace, release and re-drag to switch again

Usage: python workspace-drag.py
Requirements: python-evdev, hyprland
"""

import os
import sys
import subprocess
import signal
from evdev import InputDevice, ecodes, list_devices
from select import select

# Configuration - Edit these values to customize behavior
MIDDLE_MOUSE_CODE = ecodes.BTN_MIDDLE  # 274
THRESHOLD = 100  # pixels - how far to drag before switching
REVERSE = False  # False = drag right for next workspace, True = reversed
MODIFIER_KEY = None  # Optional: "KEY_LEFTMETA" for SUPER, "KEY_LEFTALT" for ALT, or None

# Global state
dragging = False
drag_start_x = 0
drag_start_y = 0
switched_this_drag = False  # Track if we already switched during current drag
current_workspace = 1

def get_mouse_devices():
    """Find all mouse devices"""
    devices = []
    for path in list_devices():
        try:
            dev = InputDevice(path)
            capabilities = dev.capabilities()
            if ecodes.EV_KEY in capabilities:
                if ecodes.BTN_MOUSE in capabilities[ecodes.EV_KEY]:
                    devices.append(dev)
        except (OSError, KeyError):
            continue
    return devices

def get_current_workspace():
    """Get current workspace from hyprctl"""
    try:
        result = subprocess.run(['hyprctl', 'activeworkspace', '-j'], 
                              capture_output=True, text=True)
        if result.returncode == 0:
            import json
            data = json.loads(result.stdout)
            return data.get('id', 1)
    except Exception:
        pass
    return 1

def switch_workspace(direction):
    """Switch to next/previous workspace"""
    global current_workspace
    
    try:
        result = subprocess.run(['hyprctl', 'workspaces', '-j'],
                              capture_output=True, text=True)
        if result.returncode == 0:
            import json
            workspaces = json.loads(result.stdout)
            ids = sorted([w['id'] for w in workspaces])
            
            if not ids:
                return
            
            current = get_current_workspace()
            
            if direction > 0:  # Next
                next_ws = None
                for ws_id in ids:
                    if ws_id > current:
                        next_ws = ws_id
                        break
                if next_ws is None:
                    next_ws = ids[0]  # Wrap to first
            else:  # Previous
                prev_ws = None
                for ws_id in reversed(ids):
                    if ws_id < current:
                        prev_ws = ws_id
                        break
                if prev_ws is None:
                    prev_ws = ids[-1]  # Wrap to last
                next_ws = prev_ws
            
            subprocess.run(['hyprctl', 'dispatch', 'workspace', str(next_ws)])
            current_workspace = next_ws
            print(f"Switched to workspace {next_ws}")
    except Exception as e:
        print(f"Error switching workspace: {e}")

def is_modifier_held(keyboards):
    """Check if modifier key is held (if configured)"""
    if not MODIFIER_KEY:
        return True
    
    for dev in keyboards:
        try:
            keys = dev.active_keys()
            modifier_code = getattr(ecodes, MODIFIER_KEY, None)
            if modifier_code and modifier_code in keys:
                return True
        except:
            continue
    return False

def get_cursor_pos():
    """Get current cursor position from hyprctl"""
    try:
        result = subprocess.run(
            ['hyprctl', 'cursorpos'],
            capture_output=True, text=True
        )
        if result.returncode == 0:
            pos = result.stdout.strip().split(',')
            return int(pos[0]), int(pos[1])
    except:
        pass
    return None, None

def signal_handler(sig, frame):
    """Handle Ctrl+C gracefully"""
    print("\nStopping workspace drag switcher...")
    sys.exit(0)

def main():
    global dragging, drag_start_x, drag_start_y, switched_this_drag
    
    signal.signal(signal.SIGINT, signal_handler)
    
    print("Middle Mouse Drag Workspace Switcher for Hyprland")
    print("=================================================")
    print(f"Threshold: {THRESHOLD}px")
    print(f"Reverse: {REVERSE}")
    print(f"Modifier: {MODIFIER_KEY or 'None'}")
    print()
    print("macOS-style behavior: Each drag switches ONE workspace")
    print("Hold middle mouse, drag past threshold, release to complete")
    print("Repeat to switch more workspaces")
    print()
    print("Press Ctrl+C to exit")
    print()
    
    # Find mouse devices
    mice = get_mouse_devices()
    if not mice:
        print("Error: No mouse devices found!")
        sys.exit(1)
    
    print(f"Found {len(mice)} mouse device(s)")
    for mouse in mice:
        print(f"  - {mouse.name}")
    
    print()
    
    # Also grab keyboard devices for modifier checking
    keyboards = []
    if MODIFIER_KEY:
        for path in list_devices():
            try:
                dev = InputDevice(path)
                if ecodes.EV_KEY in dev.capabilities():
                    keyboards.append(dev)
            except:
                continue
    
    all_devices = mice + keyboards
    
    try:
        while True:
            # Wait for events on any device
            readable, _, _ = select(all_devices, [], [], 0.1)
            
            for dev in readable:
                try:
                    for event in dev.read():
                        if event.type == ecodes.EV_KEY:
                            if event.code == MIDDLE_MOUSE_CODE:
                                if event.value == 1:  # Press
                                    if not MODIFIER_KEY or is_modifier_held(keyboards):
                                        dragging = True
                                        switched_this_drag = False
                                        # Record starting position
                                        x, y = get_cursor_pos()
                                        if x is not None:
                                            drag_start_x = x
                                            drag_start_y = y
                                        
                                elif event.value == 0:  # Release
                                    dragging = False
                                    switched_this_drag = False
                        
                        elif event.type == ecodes.EV_REL and dragging and not switched_this_drag:
                            # Only process movement if we haven't switched yet this drag
                            if event.code == ecodes.REL_X:
                                current_x, current_y = get_cursor_pos()
                                if current_x is not None:
                                    delta_x = current_x - drag_start_x
                                    
                                    # Check if dragged past threshold
                                    if abs(delta_x) > THRESHOLD:
                                        # Natural scrolling: drag left -> next workspace
                                        # drag right -> previous workspace
                                        direction = -1 if delta_x > 0 else 1
                                        if REVERSE:
                                            direction = -direction
                                        
                                        switch_workspace(direction)
                                        switched_this_drag = True  # Mark as switched for this drag
                                    
                except OSError:
                    continue
                    
    except KeyboardInterrupt:
        print("\nExiting...")

if __name__ == "__main__":
    main()
