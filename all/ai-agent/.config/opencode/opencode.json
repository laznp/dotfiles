{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "compatibility": "compatible"
      },
      "models": {
        "gemma4:e4b": {
          "name": "Gemma4 E4B (Local)",
          "options": {
            "num_ctx": 65536
          }
        }
      }
    }
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3"
  ],
  "default_agent": "overlord",
  "agent": {
    "overlord": {
      "description": "Shadowforce commander — routes missions, delegates to skills, reports to you",
      "model": "opencode-go/deepseek-v4-pro"
    }
  },
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": [
        "/home/laznp/Downloads/kubernetes-mcp-server",
        "--read-only"
      ]
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "slack-mcp-server@latest",
        "--transport",
        "stdio"
      ],
      "environment": {
        "SLACK_MCP_XOXP_TOKEN": "{env:SLACK_MCP_XOXP_TOKEN}",
        "SLACK_MCP_ADD_MESSAGE_TOOL": "partai-infra-reliability-indonesia"
      }
    },
    "github": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "-e",
        "GITHUB_HOST",
        "-e",
        "GITHUB_READ_ONLY=1",
        "ghcr.io/github/github-mcp-server"
      ]
    },
    "grafana": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL",
        "-e",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "grafana/mcp-grafana",
        "-t",
        "stdio"
      ],
      "environment": {
        "GRAFANA_URL": "{env:GRAFANA_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_SERVICE_ACCOUNT_TOKEN}",
        "GRAFANA_ORG_ID": "1"
      }
    }
  }
}
