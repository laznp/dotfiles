# ── Autobahn ──
function autobahn_db() {
    if [ "$1" = "pq" ]; then
        DB_NAME="${2:-postgres}"
        PGPASSWORD=$(autobahn_db_secret "prod" "postgres") psql -h localhost -U root "$DB_NAME"
    elif [ "$1" = "dwh" ]; then
        PGPASSWORD=$(autobahn_db_secret "prod" "dwh") psql -h localhost -U root datawarehouse -p 5434
    elif [ "$1" = "mysql" ]; then
        MYSQL_PWD=$(autobahn_db_secret "prod" "mysql") mariadb -uroot --socket=/var/run/mysqld/mysqld.sock
    fi
}

function autobahn_vpn() {
    if [ "$1" = "up" ]; then
        wg-quick up wg0
    elif [ "$1" = "down" ]; then
        wg-quick down wg0
    else
        echo "Parameter Not Found!!"
    fi
}

function autobahn_db_secret() {
    local env="$1" db="$2"
    local secret_path
    local secret_var="AUTOBAHN_SECRET_${env^^}_${db^^}"
    secret_path="${(P)secret_var}"
    if [[ -z "$secret_path" ]]; then
        echo "ERROR: secret path $secret_var not set" >&2
        return 1
    fi
    local profile="sso-admin-${env}"
    aws secretsmanager get-secret-value \
        --secret-id "$secret_path" \
        --profile "$profile" \
        | jq -r '.SecretString | fromjson | .password'
}

function autobahn() {
    if [ "$1" = "db-secrets" ]; then
        shift
        autobahn_db_secret "$@"
    elif [ "$1" = "db" ]; then
        shift
        autobahn_db "$@"
    elif [ "$1" = "vpn" ]; then
        shift
        autobahn_vpn "$@"
    fi
}

# ── Git ──
function clear-branch() {
    local one_month_ago
    if [[ "$OSTYPE" == "darwin"* ]]; then
        one_month_ago=$(date -v-1m +%s)
    else
        one_month_ago=$(date -d '1 month ago' +%s)
    fi
    git for-each-ref --format='%(committerdate:short) %(refname:short)' refs/heads/ | \
    while read -r date branch; do
      if [[ $(date -d "$date" +%s 2>/dev/null || date -j -f '%Y-%m-%d' "$date" +%s 2>/dev/null) -lt $one_month_ago ]]; then
        echo "Deleting $branch"
        git branch -D "$branch"
      fi
    done
}

