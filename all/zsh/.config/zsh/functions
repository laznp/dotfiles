# ── Password ──
function passgen() {
    tr -dc 'A-Za-z0-9!@#$%^&*()_+-=' < /dev/urandom | head -c "$1" ; echo
}

# ── Python venv ──
function pyenv() {
    if [ -z "$1" ]; then
        python3 -m venv venv
        source ./venv/bin/activate
    else
        python3 -m venv "$1"
        source ./"$1"/bin/activate
    fi
}

function activate() {
    if [ -z "$1" ]; then
        source ./venv/bin/activate
    else
        source ./"$1"/bin/activate
    fi
}

# ── K8s ──
function natsbox {
    NATS_BOX=$(kubectl get pod -n nats | grep nats-box | cut -d ' ' -f1)
    kubectl exec -i -t -n nats $NATS_BOX -c nats-box -- sh
}

function pg() {
    local context="${1:-dev}"
    local pod_name="${context}-hetzner-postgresql-primary-0"
    local namespace="postgresql"
    echo "Connecting to PostgreSQL in $context cluster as root..."
    kubectl exec -it -n $namespace $pod_name -- bash -c "export PGPASSWORD=\$POSTGRES_PASSWORD && psql -U root -d postgres"
}

